# Copy to .env for local dev. Docker Compose sets these via its own env.
DATABASE_URL=postgresql+psycopg://formulase:formulase@localhost:5432/formulase

# Bootstrap admin, created on first startup if it doesn't exist.
BOOTSTRAP_ADMIN_EMAIL=admin@formula.se
BOOTSTRAP_ADMIN_PASSWORD=changeme123
BOOTSTRAP_ADMIN_NAME=Admin

# Registration invite code (rotatable later via the admin UI).
DEFAULT_INVITE_CODE=FORMULA-SE

# Backblaze B2 (leave blank to use the local filesystem store in dev).
B2_ENDPOINT_URL=
B2_REGION=us-east-005
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=formula-se
LOCAL_STORAGE_DIR=/tmp/formula-se-storage

# Feature flags
SERVER_PUSH_ENABLED=false
PREPARED_WORLD_TTL_HOURS=24
